NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://yourdomain.com

# Paydestal Payment Gateway
# Get these from your Paydestal dashboard
PAYDESTAL_PUBLIC_KEY=your_live_public_key
PAYDESTAL_SECRET_KEY=your_live_secret_key
PAYDESTAL_MODE=production

# Paydestal Webhooks
PAYDESTAL_SANDBOX_WEBHOOK_URL=https://yourdomain.com/?wc-api=wc_paydestal-sandbox
PAYDESTAL_LIVE_WEBHOOK_URL=https://yourdomain.com/?wc-api=wc_paydestal

# PocketBase Database
POCKETBASE_URL=http://localhost:8090

# WhatsApp Notifications (Optional)
# Set to 'false' to disable WhatsApp receipts
WHATSAPP_INTEGRATION_ENABLED=true

# WhatsApp Business Account (Get from your WhatsApp service provider)
WHATSAPP_BUSINESS_PHONE_NUMBER=+234XXXXXXXXXX
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_INSTANCE_ID=your_whatsapp_instance_id

# Kitchen Contact Number (Where order notifications are sent)
KITCHEN_WHATSAPP_NUMBER=+234XXXXXXXXXX

